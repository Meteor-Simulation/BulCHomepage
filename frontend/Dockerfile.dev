# Frontend 개발용 Dockerfile (Vite)
# Hot reload 지원 (Vite HMR)

FROM node:20-alpine

WORKDIR /app

# 패키지 파일 복사 및 의존성 설치
COPY package*.json ./
RUN npm install

# 빌드 설정 + 진입점 파일 복사
COPY vite.config.ts tsconfig.json index.html ./
COPY public ./public
COPY src ./src

EXPOSE 3000

# Vite dev server (host 0.0.0.0, port 3000)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
